# Environment variables template
# Copy this file to .env.local and fill in actual values

# Email configuration (for contact form)
VITE_CONTACT_EMAIL=your-email@example.com

# Turnstile/CAPTCHA (optional)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Analytics (optional)
VITE_ANALYTICS_ID=your-analytics-id

# Supabase (vector search for chat)
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only (Vercel Functions)
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENROUTER_API_KEY=your-openrouter-api-key

# LinkedIn OAuth
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id
VITE_LINKEDIN_REDIRECT_URI=http://localhost:5173/api/linkedin-callback
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Do NOT commit .env.local or any secrets files
